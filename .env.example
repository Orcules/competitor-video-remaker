# Video Scene Processor - Environment Variables
# ==============================================
# Copy this file to .env and fill in your actual values

# Google Sheets Configuration
SERVICE_ACCOUNT_FILE=service_account.json
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_SHEET_TAB=Input

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Kie.ai API Key (for Nano Banana and Runway)
KIE_API=your-kie-api-key-here

# Rendi.dev API Key
RENDI_API_KEY=your-rendi-api-key-here

# ElevenLabs API Key
ELEVEN_LABS_API_KEY=your-elevenlabs-api-key-here

# ZapCap API Key (for subtitles)
ZAPCAP_API_KEY=your-zapcap-api-key-here
ZAPCAP_TEMPLATE_ID=your-zapcap-template-id

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1


# Gemini video analysis
GOOGLE_API_KEY=your-google-api-key-here
# Google Cloud Storage
GCS_CREDENTIALS_FILE=service_account.json
GCS_BUCKET_NAME=your-gcs-bucket
GCS_FOLDER_NAME=your-gcs-folder
GCS_VIDEO_BUCKET_NAME=your-gcs-video-bucket
